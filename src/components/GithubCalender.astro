---
import { getCalendarData } from "../services/calendar";

const calendar = await getCalendarData();
---

<section
  class="bg-[#0d1117] border border-gray-700 rounded-xl p-6 max-w-4xl mx-auto my-8 font-sans"
>
  {
    calendar ? (
      <>
        <div class="flex justify-between items-center mb-4 text-gray-300">
          <h3 class="text-sm font-semibold">Contribuciones en el último año</h3>
          <span class="text-xs">{calendar.totalContributions} total</span>
        </div>

        <div class="flex gap-1 overflow-x-auto pb-2 scrollbar-hide">
          {calendar.weeks.map((week) => (
            <div class="flex flex-col gap-1 shrink-0">
              {week.contributionDays.map((day) => (
                <div
                  class="w-2.5 h-2.5 rounded-xxs transition-transform hover:scale-150"
                  style={{
                    backgroundColor:
                      day.color === "#ebedf0" ? "#161b22" : day.color,
                  }}
                  title={`${day.date}: ${day.contributionCount} contribuciones`}
                />
              ))}
            </div>
          ))}
        </div>

        <div class="flex items-center gap-2 mt-4 text-2xs text-gray-400 justify-end">
          <span>Less</span>
          <div class="flex gap-1">
            <div class="w-2.5 h-2.5 bg-[#161b22] rounded-xxs" />
            <div class="w-2.5 h-2.5 bg-[#0e4429] rounded-xxs" />
            <div class="w-2.5 h-2.5 bg-[#006d32] rounded-xxs" />
            <div class="w-2.5 h-2.5 bg-[#26a641] rounded-xxs" />
            <div class="w-2.5 h-2.5 bg-[#39d353] rounded-xxs" />
          </div>
          <span>More</span>
        </div>
      </>
    ) : (
      <div class="text-red-400 text-center">
        No se pudieron cargar los datos del calendario de GitHub.
      </div>
    )
  }
</section>
