---

---

<section
  class="box max-w-7xl mx-auto px-8 grid grid-cols-1 md:grid-cols-12 gap-12 place-items-center min-h-screen"
  id="home"
>
  <div
    class="left-side md:col-span-7 space-y-8 flex flex-col justify-center items-center md:items-start text-center md:text-left"
  >
    <div class="space-y-4">
      <span
        class="badge-text text-sm tracking-[0.4em] font-medium uppercase text-green-500"
        >Ingeniero de Software
      </span>
      <h1
        class="text-4xl md:text-6xl lg:text-7xl xl:text-8xl font-black max-w-xs lg:max-w-xl tracking-tighter leading-tight text-on-surface"
      >
        <span class="title-line block">Desarrollador</span>
        <span class="title-line block text-green-500">Full-Stack Jr</span>
      </h1>
    </div>
    <p class="hero-description text-xl max-w-2xl">
      Desarrollador full-stack especializado en la creación de soluciones
      digitales a medida. Aunque estoy en las primeras etapas de mi carrera como
      desarrollador, creo tener una base sólida para crear productos
      funcionales, escalables y visualmente coherentes.
    </p>
    <div class="flex gap-4">
      <button
        class="hero-cta bg-linear-to-b from-white via-gray-400 to-blue-900/10 rounded-2xl opacity-0
                bg-size-[100%_200%]
                bg-position-[0%_0%]
                hover:bg-position-[0%_100%]
                transition-all duration-700 ease-in-out text-on-primary px-8 py-4
                font-label font-bold text-sm uppercase tracking-widest cursor-pointer text-black hover:text-white"
      >
        <a
          href="/CV-LuisPalacios2026.pdf"
          target="_blank"
          rel="noopener noreferrer"
          download="CV-LuisPalacios2026.pdf"
        >
          Descargar CV
        </a>
      </button>
    </div>
  </div>
  <div class="rigth-side md:col-span-5 relative group">
    <div
      class="relative bg-surface-container-low p-2 rounded-4xl overflow-hidden border border-outline-variant/15 shadow-xl shadow-gray-500"
    >
      <img
        class="w-full h-125 object-cover rounded-xl grayscale hover:grayscale-0 transition-all duration-500"
        data-alt="Professional studio portrait of a modern software engineer in a dark tech-focused environment with subtle blue rim lighting"
        src="developer.jpg"
      />
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const tl = gsap.timeline({ defaults: { ease: "power3.out" } });

  tl.from(".badge-text", {
    duration: 0.8,
    opacity: 0,
    y: -20,
    stagger: 0.1,
  })
    .from(
      ".title-line",
      {
        duration: 1,
        opacity: 0,
        x: -50,
        stagger: 0.2,
      },
      "-=0.4",
    )
    .from(
      ".hero-description",
      {
        duration: 0.8,
        opacity: 0,
        y: 20,
      },
      "-=0.5",
    )
    .from(
      ".hero-cta",
      {
        duration: 0.6,
        opacity: 1,
        scale: 0.9,
      },
      "-=0.3",
    )
    .from(
      ".rigth-side",
      {
        duration: 1.2,
        opacity: 0,
        x: 100,
        rotation: 5,
      },
      "-=0.8",
    );

  gsap.to(".rigth-side", {
    scrollTrigger: {
      trigger: ".rigth-side",
      start: "top bottom",
      end: "bottom top",
      scrub: 1,
    },
    y: -50,
  });
</script>
