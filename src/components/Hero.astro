<section
  class="max-w-7xl mx-auto px-8 grid grid-cols-1 md:grid-cols-12 gap-12 items-center min-h-179"
  id="home"
>
  <div class="md:col-span-7 space-y-8">
    <div class="space-y-4">
      <span
        class="text-sm tracking-[0.4em] font-medium uppercase text-green-500"
        >Engineering lead</span
      >
      <h1
        class="text-6xl md:text-8xl font-black tracking-tighter leading-tight text-on-surface"
      >
        Junior Full Stack Developer
      </h1>
    </div>
    <p class="text-xl max-w-2xl">
      Crafting scalable digital ecosystems with a focus on performance,
      security, and editorial aesthetics. Specialist in React, Astro, and
      Tailwind.
    </p>
    <div class="flex gap-4">
      <button
        class="bg-linear-to-br from-blue-200 from-10% via-blue-500 via-30% text-on-primary px-8 py-4 rounded-xl font-label font-bold text-sm uppercase tracking-widest cursor-pointer text-black"
      >
        Start Exploration
      </button>
      <button
        class="px-8 py-4 rounded-xl font-bold text-sm uppercase tracking-widest text-on-surface-variant hover:bg-surface-container-high transition-colors"
      >
        View Archive
      </button>
    </div>
  </div>
  <div class="md:col-span-5 relative group">
    <div
      class="absolute inset-0 bg-primary/20 blur-[100px] rounded-full group-hover:bg-primary/30 transition-all duration-700"
    >
    </div>
    <div
      class="relative bg-surface-container-low p-2 rounded-4xl overflow-hidden border border-outline-variant/15"
    >
      <img
        class="w-full h-125 object-cover rounded-xl grayscale hover:grayscale-0 transition-all duration-500"
        data-alt="Professional studio portrait of a modern software engineer in a dark tech-focused environment with subtle blue rim lighting"
