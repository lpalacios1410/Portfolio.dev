---
import { Image } from "astro:assets";
interface Props {
  title: string;
  subtitle: string;
  category: string;
  description: string;
  languages: { label: string; icon: any }[];
  status: string;
  imageSrc: ImageMetadata; // Usamos este tipo para imágenes locales
  imageAlt: string;
  urlProject: string;
  urlDemo: string;
}

const {
  title,
  description,
  languages,
  subtitle,
  status,
  imageSrc,
  imageAlt,
  category,
  urlProject,
  urlDemo,
} = Astro.props;
---

<div
  class="bg-gray-500/20 rounded-2xl overflow-hidden group hover:translate-y-8px transition-transform duration-300"
>
  <div class="w-full h-48 overflow-hidden bg-surface-container-lowest">
    <Image
      class="w-full h-full object-cover group-hover:scale-105 group-hover:opacity-100 transition-all duration-700"
      src={imageSrc}
      alt={imageAlt}
    />0
  </div>
  <div class="p-8 space-y-4 flex flex-col">
    <div
      class="flex flex-col justify-between items-center gap-4 lg:flex-row lg:items-start"
    >
      <h2 class="text-2xl font-bold text-primary">{title}</h2>
    </div>
    <div class="flex flex-row gap-2 font-bold text-xs">
      <h4 class="p-1.5 bg-black/50 rounded-xl text-center">
        <span>{subtitle}</span>
      </h4>
      <h4 class="p-1.5 bg-black/50 rounded-xl text-center">
        <span>{category}</span>
      </h4>
      <h5
        class="p-2 bg-green-500/20 rounded-xl text-center flex items-center gap-1"
      >
        <span class="opacity-70">{status}</span><div
          class="w-2 h-2 bg-green-500 rounded-full animate-pulse"
        >
        </div>
      </h5>
    </div>
    <p class="text-on-surface-variant text-sm leading-relaxed">
      {description}
    </p>
    <div class="flex text-center gap-1">
      {
        languages.map(({ icon: Icon, label }) => (
          <div class="font-bold flex flex-col justify-center items-center text-center text-2xs ">
            <Icon
              class=" rounded-2xl cursor-pointer border-0 p-0.5 bg-white/10"
              size={1}
              width={30}
              height={30}
            />{" "}
            <span>{label}</span>
          </div>
        ))
      }
    </div>
    <div class="w-full h-auto flex flex-row justify-between gap-2 text-center">
      <a
        class="bg-black/50 shadow-lg shadow-white/10 p-1.5 rounded-xs font-bold w-1/2 flex items-center justify-center"
        href={urlDemo}
        target="_blank"
        rel="noopener noreferrer"
      >
        Demo</a
      >
      <a
        class="bg-black/50 shadow-lg shadow-white/10 p-1.5 rounded-xs font-bold w-1/2 flex flex-col items-center"
        href={urlProject}
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg viewBox="0 0 1024 1024" fill="none" class="w-5"
          ><path
            fill-rule="evenodd"
            clip-rule="evenodd"
            d="M8 0C3.58 0 0 3.58 0 8C0 11.54 2.29 14.53 5.47 15.59C5.87 15.66 6.02 15.42 6.02 15.21C6.02 15.02 6.01 14.39 6.01 13.72C4 14.09 3.48 13.23 3.32 12.78C3.23 12.55 2.84 11.84 2.5 11.65C2.22 11.5 1.82 11.13 2.49 11.12C3.12 11.11 3.57 11.7 3.72 11.94C4.44 13.15 5.59 12.81 6.05 12.6C6.12 12.08 6.33 11.73 6.56 11.53C4.78 11.33 2.92 10.64 2.92 7.58C2.92 6.71 3.23 5.99 3.74 5.43C3.66 5.23 3.38 4.41 3.82 3.31C3.82 3.31 4.49 3.1 6.02 4.13C6.66 3.95 7.34 3.86 8.02 3.86C8.7 3.86 9.38 3.95 10.02 4.13C11.55 3.09 12.22 3.31 12.22 3.31C12.66 4.41 12.38 5.23 12.3 5.43C12.81 5.99 13.12 6.7 13.12 7.58C13.12 10.65 11.25 11.33 9.47 11.53C9.76 11.78 10.01 12.26 10.01 13.01C10.01 14.08 10 14.94 10 15.21C10 15.42 10.15 15.67 10.55 15.59C13.71 14.53 16 11.53 16 8C16 3.58 12.42 0 8 0Z"
            transform="scale(64)"
            fill="#ffff"></path></svg
        >Ver codigo</a
      >
    </div>
  </div>
</div>
