---
import { Image } from "astro:assets";
interface Props {
  title: string;
  subtitle: string;
  category: string;
  description: string;
  languages: { label: string; icon: any }[];
  status: string;
  imageSrc: ImageMetadata;
  imageAlt: string;
  urlProject: string;
  urlDemo: string;
  index?: number;
}

const {
  title,
  description,
  languages,
  subtitle,
  status,
  imageSrc,
  imageAlt,
  category,
  urlProject,
  urlDemo,
  index = 0,
} = Astro.props;
---

<div
  class="project-card group relative bg-gray-500/10 rounded-2xl overflow-hidden border border-white/5 hover:border-green-500/30 transition-all duration-500"
>
  <div class="w-full h-48 overflow-hidden bg-surface-container-lowest relative">
    <div
      class="absolute inset-0 bg-linear-to-t from-black/80 via-transparent to-transparent z-10 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end justify-center pb-4"
    >
      <a
        href={urlDemo}
        target="_blank"
        rel="noopener noreferrer"
        class="bg-green-500/20 backdrop-blur-sm border border-green-500/50 text-green-400 px-4 py-2 rounded-full font-bold text-sm hover:bg-green-500/40 transition-all duration-300"
      >
        Ver Demo
      </a>
    </div>
    <picture>
      <Image
        class="w-full h-full object-cover group-hover:scale-110 transition-all duration-700"
        src={imageSrc}
        alt={imageAlt}
      />
    </picture>
  </div>
  <div class="p-6 space-y-4 flex flex-col">
    <div class="flex flex-col justify-between items-start gap-2">
      <h2
        class="text-2xl font-bold text-on-surface group-hover:text-green-400 transition-colors duration-300"
      >
        {title}
      </h2>
      <span
        class="text-xs text-green-500 font-mono bg-green-500/10 px-2 py-1 rounded-full"
        >{status}</span
      >
    </div>
    <div class="flex flex-wrap gap-2">
      <span
        class="px-3 py-1 bg-white/5 rounded-full text-xs font-medium text-gray-300"
        >{subtitle}</span
      >
      <span
        class="px-3 py-1 bg-white/5 rounded-full text-xs font-medium text-gray-300"
        >{category}</span
      >
    </div>
    <p
      class="text-gray-400 text-sm leading-relaxed line-clamp-3 group-hover:line-clamp-none transition-all duration-300"
    >
      {description}
    </p>
    <div class="flex flex-wrap gap-3 pt-2">
      {
        languages.map(({ icon: Icon, label }) => (
          <div class="flex items-center gap-1.5 text-xs text-gray-400 bg-white/5 px-2 py-1 rounded-lg group-hover:bg-white/10 transition-colors duration-300">
            <Icon class="w-4 h-4" />
            <span>{label}</span>
          </div>
        ))
      }
    </div>
    <div class="flex gap-3 pt-2">
      <svg viewBox="0 0 1024 1024" fill="none" class="w-5"
        ><path
          fill-rule="evenodd"
          clip-rule="evenodd"
          d="M8 0C3.58 0 0 3.58 0 8C0 11.54 2.29 14.53 5.47 15.59C5.87 15.66 6.02 15.42 6.02 15.21C6.02 15.02 6.01 14.39 6.01 13.72C4 14.09 3.48 13.23 3.32 12.78C3.23 12.55 2.84 11.84 2.5 11.65C2.22 11.5 1.82 11.13 2.49 11.12C3.12 11.11 3.57 11.7 3.72 11.94C4.44 13.15 5.59 12.81 6.05 12.6C6.12 12.08 6.33 11.73 6.56 11.53C4.78 11.33 2.92 10.64 2.92 7.58C2.92 6.71 3.23 5.99 3.74 5.43C3.66 5.23 3.38 4.41 3.82 3.31C3.82 3.31 4.49 3.1 6.02 4.13C6.66 3.95 7.34 3.86 8.02 3.86C8.7 3.86 9.38 3.95 10.02 4.13C11.55 3.09 12.22 3.31 12.22 3.31C12.66 4.41 12.38 5.23 12.3 5.43C12.81 5.99 13.12 6.7 13.12 7.58C13.12 10.65 11.25 11.33 9.47 11.53C9.76 11.78 10.01 12.26 10.01 13.01C10.01 14.08 10 14.94 10 15.21C10 15.42 10.15 15.67 10.55 15.59C13.71 14.53 16 11.53 16 8C16 3.58 12.42 0 8 0Z"
          transform="scale(64)"
          fill="#ffff"></path></svg
      ><a
        class="flex-1 bg-white/5 text-white text-center py-2 rounded-xl font-bold text-sm hover:bg-white/10 transition-all duration-300"
        href={urlProject}
        target="_blank"
        rel="noopener noreferrer"
      >
        Código
      </a>
    </div>
  </div>
</div>
