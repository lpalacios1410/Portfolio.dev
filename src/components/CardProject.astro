---
import { Image } from "astro:assets";
interface Props {
  title: string;
  subtitle: string;
  category: string;
  description: string;
  languages: { label: string; icon: any }[];
  status: string;
  imageSrc: ImageMetadata; // Usamos este tipo para imágenes locales
  imageAlt: string;
  urlProject: string;
  urlDemo: string;
}

const {
  title,
  description,
  languages,
  subtitle,
  status,
  imageSrc,
  imageAlt,
  category,
  urlProject,
  urlDemo,
} = Astro.props;
---

<div
  class="bg-gray-500/20 rounded-2xl overflow-hidden group hover:translate-y-8px transition-transform duration-300"
>
  <div class="w-full h-48 overflow-hidden bg-surface-container-lowest">
    <Image
      class="w-full h-full object-cover group-hover:scale-105 group-hover:opacity-100 transition-all duration-700"
      src={imageSrc}
      alt={imageAlt}
    />0
  </div>
  <div class="p-8 space-y-4 flex flex-col">
    <div
      class="flex flex-col justify-between items-center gap-4 lg:flex-row lg:items-start"
    >
      <h2 class="text-2xl font-bold text-primary">{title}</h2>
    </div>
    <div class="flex flex-row gap-2 font-bold text-xs">
      <h4 class="p-1.5 bg-black/50 rounded-xl">{subtitle}</h4>
      <h4 class="p-1.5 bg-black/50 rounded-xl">{category}</h4>
    </div>
    <p class="text-on-surface-variant text-sm leading-relaxed">
      {description}
    </p>
    <div class="flex flex-wrap gap-2">
      {
        languages.map(({ icon: Icon, label }) => (
          <div class="font-bold flex flex-col justify-center items-center">
            <Icon size={1} width={25} height={25} /> <span>{label}</span>
          </div>
        ))
      }
    </div>
    <button
      class="bg-black/50 shadow-lg shadow-white/10 p-1.5 rounded-xs font-bold"
    >
      <a href={urlDemo}> Demo</a>
    </button>
    <button
      class="bg-black/50 shadow-lg shadow-white/10 p-1.5 rounded-xs font-bold"
    >
      <a href={urlProject}> Ver codigo</a>
    </button>
  </div>
</div>
