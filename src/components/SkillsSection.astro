---
import SkillCard from "./SkillCard.astro";
---

<section
  class="skills py-12 mt-5 mb-5 relative scroll-mt-20"
  style="background: var(--color-surface-container-low)"
>
  <div class="mb-16 text-center">
    <div class="flex items-center justify-center gap-4 mb-4">
      <h2
        class="text-3xl md:text-5xl font-black tracking-widest flex items-center gap-4"
        style="color: var(--color-on-surface)"
      >
        Habilidades
      </h2>
    </div>
  </div>
  <div class="max-w-7xl mx-auto px-8">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-16">
      <div
        class="col-span-4 md:col-span-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8"
      >
        <!-- Frontend Stack -->
        <SkillCard
          title="FRONTEND"
          borderColor="border-blue-500"
          icons={[
            { name: "html", label: "HTML 5" },
            { name: "css", label: "CSS 3" },
            { name: "javascript", label: "JavaScript" },
            { name: "react", label: "React" },
            { name: "astro", label: "Astro" },
            { name: "tailwindcss", label: "Tailwind" },
            { name: "bootstrap", label: "Bootstrap" },
          ]}
        />
        <!-- Backend Stack -->
        <SkillCard
          title="BACKEND"
          borderColor="border-green-500"
          icons={[
            { name: "nodejs", label: "Node JS" },
            { name: "expressjs", label: "Express" },
            { name: "python", label: "Python" },
            { name: "postgresql", label: "PostgreSQL" },
          ]}
        />
        <!-- Tools Stack -->
        <SkillCard
          title="HERRAMIENTAS"
          borderColor="border-red-500"
          icons={[
            { name: "github", label: "Github" },
            { name: "git", label: "Git" },
            { name: "copilot", label: "Copilot" },
            { name: "vscode", label: "VSCode" },
            { name: "postman", label: "Postman" },
            { name: "docker", label: "Docker" },
            { name: "playwright", label: "Playwright" },
          ]}
        />
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  gsap.from(".skills h2", {
    scrollTrigger: { trigger: ".skills", start: "top 80%" },
    opacity: 0,
    y: -30,
    duration: 0.8,
    ease: "back.out(1.7)",
  });

  gsap.utils.toArray(".cardSkill").forEach((card: any, i: number) => {
    gsap.from(card, {
      scrollTrigger: {
        trigger: card,
        start: "top 90%",
        toggleActions: "play none none reverse",
      },
      opacity: 0,
      y: 50,
      scale: 0.9,
      duration: 0.6,
      delay: i * 0.15,
      ease: "power2.out",
    });
  });
</script>
