---
import { Icon } from "astro-icon/components";

export interface IconItem {
  name: string;
  label: string;
}

export interface Props {
  title: string;
  borderColor: string;
  icons: IconItem[];
}

const { title, borderColor, icons } = Astro.props;
---

<div
  class={`cardSkill rounded-2xl overflow-hidden transition-transform duration-300 border-t-4 ${borderColor} bg-gray-500/30`}
>
  <div class="bg-black/40">
    <div class="flex items-center gap-8 p-2 border-b mb-3">
      <div class="flex gap-2">
        <div class="w-3 h-3 rounded-full bg-red-500"></div>
        <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
        <div class="w-3 h-3 rounded-full bg-green-500"></div>
      </div>
      <h4
        class="font-label text-lg font-bold tracking-tight w-1/2 text-center text-white/80"
      >
        {title}
      </h4>
    </div>
  </div>
  <div class="grid grid-cols-2 xs:grid-cols-3 gap-4 p-4">
    {
      icons.map((icon) => (
        <div class="flex items-center justify-center flex-col font-bold transition duration-200 hover:scale-110 cursor-pointer">
          <Icon name={icon.name} class="w-15 h-12" />
          {icon.label}
        </div>
      ))
    }
  </div>
</div>
